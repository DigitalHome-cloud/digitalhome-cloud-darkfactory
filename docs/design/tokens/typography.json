{
  "$schema": "dhc-design-tokens-v1",
  "version": "1.0.0",
  "description": "DigitalHome.Cloud typography tokens",

  "fontFamily": {
    "sans":  { "value": "system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif", "description": "Default UI font — uses platform native font" },
    "mono":  { "value": "\"SF Mono\", \"Fira Code\", SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace", "description": "Code, technical values, URIs" }
  },

  "fontSize": {
    "2xs":  { "value": "0.65rem", "px": "10.4px", "usage": "Tiny badges, counts, icon labels" },
    "xs":   { "value": "0.7rem",  "px": "11.2px", "usage": "Sidebar labels, secondary captions" },
    "sm":   { "value": "0.75rem", "px": "12px",   "usage": "Form labels, table cells, nav pills" },
    "base": { "value": "0.8rem",  "px": "12.8px", "usage": "Input fields, panel titles, default UI text" },
    "md":   { "value": "0.85rem", "px": "13.6px", "usage": "Navigation links, buttons, body text" },
    "lg":   { "value": "0.9rem",  "px": "14.4px", "usage": "Panel headers, section headings" },
    "xl":   { "value": "1.0rem",  "px": "16px",   "usage": "Canvas controls, tile titles" },
    "2xl":  { "value": "1.1rem",  "px": "17.6px", "usage": "Section titles, form headings" },
    "3xl":  { "value": "1.5rem",  "px": "24px",   "usage": "Page headings (h2)" },
    "4xl":  { "value": "1.8rem",  "px": "28.8px", "usage": "Page titles (h1)" },
    "hero": { "value": "2.25rem", "px": "36px",   "usage": "Hero titles, landing page headings" }
  },

  "fontWeight": {
    "normal":   { "value": 400, "usage": "Body text, descriptions" },
    "medium":   { "value": 500, "usage": "Labels, form fields, active tabs" },
    "semibold": { "value": 600, "usage": "Section headers, nav links, buttons, tile titles" },
    "bold":     { "value": 700, "usage": "Page titles, hero titles, logo text" }
  },

  "lineHeight": {
    "dense":  { "value": 1.1,  "usage": "Headings, single-line labels" },
    "tight":  { "value": 1.4,  "usage": "Comments, multi-line descriptions" },
    "normal": { "value": 1.5,  "usage": "Body text default" },
    "loose":  { "value": 1.75, "usage": "Long-form reading, articles" }
  },

  "letterSpacing": {
    "tight":   { "value": "0.03em", "usage": "Version badges, compact labels" },
    "normal":  { "value": "0.04em", "usage": "Inspector labels, form labels" },
    "wide":    { "value": "0.05em", "usage": "Sidebar section headers, uppercase text" },
    "wider":   { "value": "0.06em", "usage": "Canvas labels, emphasis uppercase" }
  }
}
