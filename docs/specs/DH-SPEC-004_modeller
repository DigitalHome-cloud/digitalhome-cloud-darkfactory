## Blockly JavaScript Definitions (v11+)

```
/**
 * DH-SPEC-01: SmartHome Spatial Hierarchy
 * Compatible with Blockly v11+
 */

// 1. ROOT: Real Estate
Blockly.Blocks['smarthome_real_estate'] = {
  init: function() {
    this.appendDummyInput()
        .appendField("🏠 Real Estate")
        .appendField(new Blockly.FieldTextInput("My Property"), "NAME");
    this.appendStatementInput("AREAS")
        .setCheck("AreaType"); 
    this.setColour(120); // Darkest Green
    this.setTooltip("The root physical container for the property.");
  }
};

// 2. BRANCH: Area (Physical subdivision like a Building or Annex)
Blockly.Blocks['smarthome_area'] = {
  init: function() {
    this.appendDummyInput()
        .appendField("📍 Area")
        .appendField(new Blockly.FieldTextInput("Main Building"), "NAME")
        .appendField("Floor")
        .appendField(new Blockly.FieldNumber(0), "FLOOR");
    this.appendStatementInput("SPACES")
        .setCheck("SpaceType");
    this.setPreviousStatement(true, "AreaType");
    this.setNextStatement(true, "AreaType");
    this.setColour(100); 
    this.setTooltip("Physical subdivision of the property.");
  }
};

// 3. LEAF: Space (Individual room or area)
Blockly.Blocks['smarthome_space'] = {
  init: function() {
    this.appendDummyInput()
        .appendField("🚪 Space")
        .appendField(new Blockly.FieldTextInput("Kitchen"), "NAME")
        .appendField("Surface")
        .appendField(new Blockly.FieldNumber(15, 0), "SURFACE")
        .appendField("m²");
    
    // Logical Many-to-Many grouping via Variables
    this.appendDummyInput()
        .appendField("🌐 Zone:")
        .appendField(new Blockly.FieldVariable("None", null, ["Zone"]), "ZONE_VAR");

    this.setPreviousStatement(true, "SpaceType");
    this.setNextStatement(true, "SpaceType");
    this.setColour(70); // Lightest Green
    this.setTooltip("Specific room assigned to a logical Zone.");
  }
};

```
# Toolbox Implementation (XML)
To enable the "Zone" variable functionality in your Gatsby Modeler, include this in your toolbox configuration:
xml
```

<xml>
  <category name="Spatial" colour="#2E7D32">
    <block type="smarthome_real_estate"></block>
    <block type="smarthome_area"></block>
    <block type="smarthome_space"></block>
  </category>
  <category name="Zones" custom="VARIABLE" variabletype="Zone">
    <button text="Create New Zone" callbackKey="CREATE_ZONE_BUTTON"></button>
  </category>
</xml>
```

